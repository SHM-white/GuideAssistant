<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GuideAssistant.Views.SubtitleOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="字幕">

    <Grid>
        <Border x:Name="SubtitleBorder" CornerRadius="12" Padding="20,12"
                Background="#CC000000" MaxWidth="800"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="SubtitleText" Text="等待字幕..." FontSize="22"
                       Foreground="White" TextWrapping="Wrap"
                       TextAlignment="Center" LineHeight="36" />
        </Border>
    </Grid>
</Window>
