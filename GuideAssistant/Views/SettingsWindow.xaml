<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GuideAssistant.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GuideAssistant.Views"
    Title="设置">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="SettingsNav" PaneDisplayMode="LeftCompact"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    OpenPaneLength="180"
                    CompactPaneLength="48"
                    SelectionChanged="SettingsNav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Icon="Keyboard" Content="快捷键" Tag="hotkeys" />
            <NavigationViewItem Icon="View"     Content="显示"   Tag="display" />
            <NavigationViewItem Icon="Help"     Content="关于"   Tag="about" />
        </NavigationView.MenuItems>

        <NavigationView.Content>
        <Grid>
            <ScrollViewer x:Name="HotkeysPage" Visibility="Visible">
            <StackPanel Spacing="8" Padding="24,16">
                <TextBlock Text="自定义快捷键" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="点击右侧按钮，然后按下你想要的按键来绑定。" FontSize="12" Opacity="0.6" Margin="0,0,0,8" />
                <ListView x:Name="HotkeyList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:HotkeyRow">
                            <Grid Padding="4,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind DisplayName}" FontSize="14" VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="{x:Bind CurrentBinding}" FontSize="13" Height="32"
                                        HorizontalAlignment="Stretch"
                                        Click="HotkeyRebind_Click" />
                                <Button Grid.Column="2" Content="X" FontSize="12"
                                        Width="32" Height="32" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Opacity="0.4"
                                        Click="HotkeyClear_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="CaptureHint" FontSize="12" Opacity="0" Margin="0,4,0,0"
                           Text="正在等待按键... 按 Esc 取消" />
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="DisplayPage" Visibility="Collapsed">
            <StackPanel Spacing="16" Padding="24,16">
                <TextBlock Text="显示设置" FontSize="18" FontWeight="SemiBold" />
                <CheckBox x:Name="SubtitleToggle" Content="启用字幕覆盖窗口" />
                <CheckBox x:Name="MinimapToggle" Content="启用小地图覆盖窗口" />
                <TextBlock Text="透明度" FontSize="14" Margin="0,8,0,0" />
                <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0"
                        StepFrequency="0.05" Width="200" HorizontalAlignment="Left" />
                <TextBlock x:Name="OpacityLabel" FontSize="12" Opacity="0.6" />
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="AboutPage" Visibility="Collapsed">
            <StackPanel Spacing="8" Padding="24,16">
                <TextBlock Text="关于" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="GuideAssistant" FontSize="16" />
                <TextBlock Text="游戏视频攻略辅助工具" FontSize="13" Opacity="0.7" />
                <TextBlock Text="v1.0.0" FontSize="12" Opacity="0.5" Margin="0,8,0,0" />
                <TextBlock Text="基于 WinUI 3 + WebView2 构建" FontSize="12" Opacity="0.5" />
            </StackPanel>
        </ScrollViewer>
        </Grid>
        </NavigationView.Content>
    </NavigationView>
</Window>
