<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GuideAssistant.Views.ToolbarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:GuideAssistant.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="工具栏">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Vertical Tab List -->
        <Grid Grid.Column="0" Background="{ThemeResource SystemChromeMediumLowColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListView x:Name="TabListView" Grid.Row="0"
                      SelectionMode="Single"
                      SelectionChanged="TabListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,6" ColumnSpacing="4" Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Title}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1" Width="28" Height="28"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="2" VerticalAlignment="Center"
                                    Click="TabFavoriteBtn_Click">
                                <SymbolIcon x:Name="TabFavIcon" Symbol="OutlineStar" />
                            </Button>

                            <Button Grid.Column="2" Width="28" Height="28"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="2" VerticalAlignment="Center"
                                    Click="TabCloseBtn_Click">
                                <SymbolIcon Symbol="Cancel" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- New Tab button -->
            <Button Grid.Row="1" Height="32" Margin="4"
                    Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    Click="NewTabBtn_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <SymbolIcon Symbol="Add" />
                    <TextBlock Text="新标签页" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Right: Navigation + Search -->
        <Grid Grid.Column="1" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:NavigationBar x:Name="NavBarControl" Grid.Row="0" />

            <AutoSuggestBox x:Name="SearchBox" Grid.Row="1"
                            PlaceholderText="搜索收藏夹..."
                            Height="30" FontSize="12" Margin="8,4"
                            QuerySubmitted="SearchBox_QuerySubmitted" />

            <ListView Grid.Row="2" x:Name="BookmarkResultsList" Margin="8,0"
                      Visibility="Collapsed"
                      SelectionChanged="BookmarkResults_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Url}" FontSize="11" Opacity="0.7" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>
