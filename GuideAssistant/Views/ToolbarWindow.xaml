<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GuideAssistant.Views.ToolbarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:GuideAssistant.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="工具栏">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TabBar -->
        <controls:TabBar x:Name="TabBarControl" Grid.Row="0" />

        <!-- NavigationBar -->
        <controls:NavigationBar x:Name="NavBarControl" Grid.Row="1" />

        <!-- Quick actions row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,4" Spacing="6">
            <Button x:Name="CloseTabBtn" Content="✕ 关闭标签" FontSize="12" Height="28"
                    Padding="10,0" Background="Transparent" BorderThickness="0"
                    Click="CloseTabBtn_Click" />
            <Button x:Name="BookmarkBtn" Content="☆ 收藏" FontSize="12" Height="28"
                    Padding="10,0" Background="Transparent" BorderThickness="0"
                    Click="BookmarkBtn_Click" />
            <AutoSuggestBox x:Name="SearchBox" PlaceholderText="搜索收藏夹..."
                            Width="180" Height="28" FontSize="12"
                            QuerySubmitted="SearchBox_QuerySubmitted" />
        </StackPanel>

        <!-- Bookmark results list -->
        <ListView Grid.Row="3" x:Name="BookmarkResultsList" Margin="8,0"
                  Visibility="Collapsed" SelectionChanged="BookmarkResults_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Url}" FontSize="11" Opacity="0.7" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
