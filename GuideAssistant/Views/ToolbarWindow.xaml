<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GuideAssistant.Views.ToolbarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:GuideAssistant.Controls"
    xmlns:models="using:GuideAssistant.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="工具栏">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <DataTemplate x:Key="FolderTemplate" x:DataType="models:BookmarkTreeNode">
                <TreeViewItem AutomationProperties.Name="{x:Bind Label}"
                              ItemsSource="{x:Bind Children}" IsExpanded="True" CanDrag="False">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="13" Margin="0,0,6,0" />
                        <TextBlock Text="{x:Bind Label}" VerticalAlignment="Center" />
                    </StackPanel>
                </TreeViewItem>
            </DataTemplate>

            <DataTemplate x:Key="BookmarkTemplate" x:DataType="models:BookmarkTreeNode">
                <TreeViewItem AutomationProperties.Name="{x:Bind Label}" CanDrag="False">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="{x:Bind Label}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind SubLabel}" FontSize="11" Opacity="0.6" Margin="19,0,0,0" />
                    </StackPanel>
                </TreeViewItem>
            </DataTemplate>

            <controls:BookmarkTreeTemplateSelector x:Key="BookmarkTreeTemplateSelector"
                FolderTemplate="{StaticResource FolderTemplate}"
                BookmarkTemplate="{StaticResource BookmarkTemplate}" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left: Vertical Tab List -->
        <ListView x:Name="TabListView" Grid.Row="1" Grid.Column="0"
                    SelectionMode="Single"
                    SelectionChanged="TabListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,6" ColumnSpacing="4" Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Title}"
                                    FontSize="12"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />

                        <Button Grid.Column="1" Width="28" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Padding="2" VerticalAlignment="Center"
                                Click="TabFavoriteBtn_Click">
                            <SymbolIcon x:Name="TabFavIcon" Symbol="OutlineStar" />
                        </Button>

                        <Button Grid.Column="2" Width="28" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Padding="2" VerticalAlignment="Center"
                                Click="TabCloseBtn_Click">
                            <SymbolIcon Symbol="Cancel" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- New Tab button -->
        <Button Grid.Row="2" Grid.Column="0" Height="32" Margin="4"
                Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Stretch"
                Click="NewTabBtn_Click">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <SymbolIcon Symbol="Add" />
                <TextBlock Text="新标签页" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <!-- Right: Navigation + Favorites -->
        <controls:NavigationBar x:Name="NavBarControl" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" />

        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="8,4,8,8"
                Background="{ThemeResource SystemChromeMediumLowColor}"
                CornerRadius="6">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Padding="8,6" ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8B7;" FontSize="13" Margin="0,0,6,0" />
                        <TextBlock Text="收藏夹" FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <AutoSuggestBox x:Name="SearchBox" Grid.Column="1"
                                    PlaceholderText="搜索..."
                                    Width="160" Height="28" FontSize="12"
                                    QuerySubmitted="SearchBox_QuerySubmitted" />
                    <Button Grid.Column="2" Width="28" Height="28" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="新建文件夹"
                            Click="NewFolderBtn_Click">
                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                    </Button>
                </Grid>

                <TreeView x:Name="BookmarksTreeView" Grid.Row="1"
                           Margin="4,0,4,4"
                           SelectionMode="Single"
                           CanDragItems="False" CanReorderItems="False"
                           ItemTemplateSelector="{StaticResource BookmarkTreeTemplateSelector}"
                           ItemInvoked="BookmarksTreeView_ItemInvoked"
                           RightTapped="BookmarksTreeView_RightTapped" />
            </Grid>
        </Border>
    </Grid>
</Window>
