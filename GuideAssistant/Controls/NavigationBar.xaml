<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GuideAssistant.Controls.NavigationBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="40">

    <Grid Padding="8,4,150,4" Background="{ThemeResource SystemChromeMediumLowColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button x:Name="BackBtn" Grid.Column="0" Background="Transparent" BorderThickness="0" Click="BackBtn_Click">
            <SymbolIcon Symbol="Back" />
        </Button>
        <Button x:Name="ForwardBtn" Grid.Column="1" Background="Transparent" BorderThickness="0" Click="ForwardBtn_Click">
            <SymbolIcon Symbol="Forward" />
        </Button>
        <Button x:Name="RefreshBtn" Grid.Column="2" Background="Transparent" BorderThickness="0" Click="RefreshBtn_Click">
            <SymbolIcon Symbol="Refresh" />
        </Button>
        <AutoSuggestBox x:Name="UrlBox" Grid.Column="3" Height="30" VerticalAlignment="Center"
                         PlaceholderText="输入网址或搜索..." FontSize="13"
                         QueryIcon="Find" QuerySubmitted="UrlBox_QuerySubmitted" KeyDown="UrlBox_KeyDown" />
        <Button x:Name="BookmarkBtn" Grid.Column="4" Background="Transparent" BorderThickness="0" Click="BookmarkBtn_Click">
            <SymbolIcon x:Name="BookmarkIcon" Symbol="OutlineStar" />
        </Button>
        <Button x:Name="SettingsBtn" Grid.Column="5" Background="Transparent" BorderThickness="0" Click="SettingsBtn_Click">
            <SymbolIcon Symbol="Setting" />
        </Button>
    </Grid>
</UserControl>
