<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GuideAssistant.Controls.WebViewContainer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Loading indicator -->
        <ProgressBar x:Name="LoadingBar" Height="2" VerticalAlignment="Top"
                     IsIndeterminate="False" Visibility="Collapsed" />

        <!-- WebView2 will be added here programmatically -->
        <Grid x:Name="WebViewHost" />
    </Grid>
</UserControl>
