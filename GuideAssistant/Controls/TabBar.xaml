<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GuideAssistant.Controls.TabBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="36">

    <Grid Background="{ThemeResource SystemChromeMediumLowColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Tab list -->
        <ScrollViewer Grid.Column="0" HorizontalScrollMode="Auto" VerticalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Hidden" VerticalAlignment="Stretch">
            <ItemsControl x:Name="TabsItemsControl" Margin="4,0,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="TabBorder" Padding="10,4" Margin="2,4" CornerRadius="6"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0"
                                Tapped="TabItem_Tapped">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TabIcon" Text="🌐" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="TabTitle" Text="{Binding Title}" FontSize="12"
                                           MaxWidth="120" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <Button x:Name="CloseTabBtn" Content="✕" FontSize="10"
                                        Width="20" Height="20" Margin="6,0,0,0"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="0" VerticalAlignment="Center"
                                        Tapped="CloseTab_Tapped" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- New tab button -->
        <Button Grid.Column="1" x:Name="NewTabBtn" Content="+" FontSize="18" Width="36" Height="28"
                Margin="2,0,4,0" Background="Transparent" BorderThickness="0"
                Click="NewTabBtn_Click" />
    </Grid>
</UserControl>
