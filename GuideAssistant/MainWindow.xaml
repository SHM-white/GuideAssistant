<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GuideAssistant.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GuideAssistant"
    xmlns:controls="using:GuideAssistant.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="GuideAssistant">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <!-- WebView fills entire window -->
        <controls:WebViewContainer x:Name="WebViewControl" />

        <!-- Ultra-thin visual title bar (top edge) -->
        <Border x:Name="TitleBarBorder"
                Height="6"
                VerticalAlignment="Top"
                Background="{ThemeResource SystemChromeLowColor}" />

        <!-- Floating controls (top-left overlay) -->
        <StackPanel x:Name="WindowButtonsPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="8,8,0,0">
            <Slider x:Name="OpacitySlider" Width="80" Height="24"
                    VerticalAlignment="Center" Margin="0,0,4,0"
                    Minimum="0.2" Maximum="1.0" Value="0.9" StepFrequency="0.05"
                    Visibility="Collapsed" />
            <Button x:Name="OpacityBtn" Width="36" Height="24"
                    Background="Transparent" BorderThickness="0"
                    Opacity="0.5" Padding="0">
                <SymbolIcon Symbol="Setting" />
            </Button>
        </StackPanel>


    </Grid>
</Window>
